rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Colección config (inventario, mesas_estado, seguridad)
    match /config/{document} {
      allow read: if true;
      // Se permite la escritura general excepto para mesas_estado que tiene sus propias reglas de seguridad
      allow write: if document != "mesas_estado";
    }

    match /config/mesas_estado {
      allow read: if true;
      allow create, delete: if true;
      // Permitir la actualización de mesas_estado solo si la mesa está libre, si se mantiene el mismo clienteUid, o si se está limpiando
      allow update: if !('clienteUid' in resource.data) || 
                      resource.data.clienteUid == null || 
                      resource.data.clienteUid == "" || 
                      request.resource.data.clienteUid == resource.data.clienteUid ||
                      request.resource.data.clienteUid == "";
    }

    // 2. Tipos de asistencia personalizada
    match /tipos_asistencia/{document} {
      allow read: if true;
      allow write: if true;
    }

    // 3. Comandas, pedidos y llamadas de asistencia
    match /mesa_pedidos/{document} {
      allow read, create: if true;
      // Permitir la actualización y eliminación solo a usuarios autenticados del staff (no anónimos)
      allow update, delete: if request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // 4. Clientes anónimos (nombres ofuscados de los QR)
    match /clientes_anonimos/{userId} {
      // El cliente solo puede escribir/modificar su propio registro
      allow write: if request.auth != null && request.auth.uid == userId;
      // Permitir la lectura para que meseros y caja puedan mostrar los nombres de clientes en mesas
      allow read: if true;
    }

    // 5. Historiales, logs y auditorías
    match /historial_stock/{document} {
      allow read, write: if true;
    }
    match /bitacora/{document} {
      allow read, write: if true;
    }
    match /intentos_fallidos_qr/{document} {
      allow create: if true;
      allow read, update, delete: if true;
    }
    match /intentos_fallidos_conexion/{document} {
      allow create: if true;
      allow read, update, delete: if true;
    }
    
    // 6. Colecciones de administración de usuarios y nómina
    match /users/{document} {
      allow read, write: if true;
    }
    match /nomina_empleados/{document} {
      allow read, write: if true;
    }
  }
}
