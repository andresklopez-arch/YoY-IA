rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar para validar pertenencia al salón de forma estricta
    function perteneceAlSalon(docObj) {
      return request.auth != null && (
        docObj == null ||
        !('data' in docObj) ||
        docObj.data == null ||
        !('salonId' in docObj.data) ||
        request.auth.token.salonId == docObj.data.salonId ||
        request.auth.token.email == 'masteradmin@yoybillar.mx' ||
        request.auth.token.email.matches('^masteradmin@.*')
      );
    }

    // 1. Colección config (inventario, mesas_estado, seguridad)
    match /config/{document} {
      allow read: if true;
      allow write: if request.auth != null && (document != "mesas_estado" && document != "mesas_estado_backup") && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }

    match /config/mesas_estado {
      allow read: if true;
      allow create, delete: if request.auth != null;
      allow update: if request.auth != null && request.resource.data.mesas is list &&
                      request.resource.data.mesas.size() <= 100;
    }

    match /config/mesas_estado_backups/historial/{document} {
      allow read: if true;
      allow write: if false;
    }

    // 2. Tipos de asistencia personalizada
    match /tipos_asistencia/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. Comandas, pedidos y llamadas de asistencia
    match /mesa_pedidos/{document} {
      allow read, write: if true;
    }

    // 4. Clientes anónimos (nombres ofuscados de los QR)
    match /clientes_anonimos/{userId} {
      allow read, write: if true;
    }

    // 5. Historiales, logs y auditorías
    match /historial_stock/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /bitacora/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && (!('metodoPago' in request.resource.data) || request.resource.data.metodoPago in ['efectivo', 'tarjeta', 'transferencia', 'spei', 'qr']) && perteneceAlSalon(request.resource);
    }
    match /intentos_fallidos_qr/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /intentos_fallidos_conexion/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    match /app_crash_logs/{document} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    
    // 6. Colecciones de administración de usuarios y nómina
    match /users/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /nomina_empleados/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }

    // 7. Fila Virtual de Espera y Log de Alertas
    match /fila_espera/{document} {
      allow read, write: if true;
    }
    match /alertas_digitales_log/{document} {
      allow read, write: if request.auth != null;
    }

    // 8. Catálogos y Operación general del Billar
    match /gastos/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && (!('metodoPago' in request.resource.data) || request.resource.data.metodoPago in ['efectivo', 'tarjeta', 'transferencia', 'spei', 'qr']) && perteneceAlSalon(request.resource);
    }
    match /historial_ocupacion/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /cocina_insumos/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /mesas/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /productos/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /torneos/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /tickets/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /nomina_asistencia/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /nomina_asistencia_log/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /used_qr_tokens/{document} {
      allow read, write: if request.auth != null;
    }
    match /presupuestos/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /nomina_pagos/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /encuestas_satisfaccion/{document} {
      allow read, write: if true;
    }
    match /auditoria_accesos/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /cortes_caja/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /mermas_auditoria/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /auditorias_cortes/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow create: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
      allow update, delete: if false;
    }
    match /conciliaciones_bancarias/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /auditoria_sistema/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /cupones_retencion/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /clientes_vip/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /mantenimientos_historicos/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /tarifas_cambios_log/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
    match /resumenes_diarios/{document} {
      allow read: if request.auth != null && perteneceAlSalon(resource);
      allow write: if request.auth != null && perteneceAlSalon(resource) && perteneceAlSalon(request.resource);
    }
  }
}
